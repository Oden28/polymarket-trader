# ════════════════════════════════════════════════════════════
# Polymarket Trading Bot – Configuration
# ════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Polymarket Authentication ────────────────────────────────
# Your Polygon wallet private key (hex, with 0x prefix)
# Export from https://reveal.polymarket.com or your Web3 wallet
POLY_PRIVATE_KEY=

# Signature type for your account:
#   0 = EOA (MetaMask, hardware wallet – default)
#   1 = Email / Magic link login
#   2 = Browser wallet proxy (Coinbase Wallet, etc.)
POLY_SIGNATURE_TYPE=0

# Your funder / proxy wallet address
# Required for signature types 1 and 2
# This is the address you deposit USDC to on Polymarket
POLY_FUNDER_ADDRESS=

# ── API Endpoints (usually no need to change) ───────────────
POLY_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
POLY_CHAIN_ID=137

# ── Risk Management (tuned for ~$500 capital) ───────────────
MAX_POSITION_SIZE_USDC=25
MAX_DAILY_LOSS_USDC=50
MAX_POSITIONS=10
MAX_TRADES_PER_DAY=20

# ── Strategy Parameters ─────────────────────────────────────
# Min edge: only trade when oracle says market is 5%+ mispriced
MIN_EDGE_PERCENTAGE=5.0
# Only trade when confidence is high
CONFIDENCE_THRESHOLD=0.65
# Fractional Kelly – 0.15 is conservative (recommended for small capital)
KELLY_FRACTION=0.15

# ── Market Filters ──────────────────────────────────────────
MIN_LIQUIDITY=10000
MIN_VOLUME_24H=5000
MAX_SPREAD=0.05

# ── Operational ─────────────────────────────────────────────
# How often to scan markets (seconds)
UPDATE_INTERVAL_SECONDS=60

# DRY_RUN=true means signals are generated but NO real orders
# are placed. Set to false only when you are ready to trade.
DRY_RUN=true

LOG_LEVEL=INFO
